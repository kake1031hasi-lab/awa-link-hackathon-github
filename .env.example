# ==============================================================================
# AWA-LINK Configuration Environment Variables (Example template)
# ==============================================================================

# ------------------------------------------------------------------------------
# Elasticsearch Configuration
# ------------------------------------------------------------------------------
# Elasticsearch URL (e.g., Elastic Cloud URL or local instance)
ELASTIC_URL=https://your-elasticsearch-endpoint.es.gcp.elastic.cloud:443

# Elasticsearch API Key for authentication
ELASTIC_API_KEY=your_elasticsearch_api_key_here

# (Optional) Basic Auth fallback if API key is not used
ELASTIC_USER=
ELASTIC_PASSWORD=

# Elasticsearch Index Name
ELASTIC_INDEX=awa-link-sr

# ------------------------------------------------------------------------------
# LINE Bot Configuration
# ------------------------------------------------------------------------------
# LINE Channel Secret (found in Channel Settings)
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# LINE Channel Access Token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ------------------------------------------------------------------------------
# Gemini API Configuration
# ------------------------------------------------------------------------------
# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Admin LINE User ID for push notifications
ADMIN_LINE_USER_ID=your_admin_line_user_id_here
